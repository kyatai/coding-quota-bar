{
  "appId": "com.codingquotabar.app",
  "productName": "Coding Quota Bar",
  "copyright": "Copyright © 2026 coding-quota-bar-team",
  "directories": {
    "output": "release",
    "buildResources": "assets"
  },
  "files": [
    "out/**/*",
    "package.json"
  ],
  "publish": {
    "provider": "github",
    "owner": "hyizhou",
    "repo": "coding-quota-bar"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["universal"]
      },
      {
        "target": "zip",
        "arch": ["universal"]
      }
    ],
    "icon": "assets/icon.icns",
    "category": "public.app-category.developer-tools",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "extendInfo": {
      "LSUIElement": true
    }
  },
  "dmg": {
    "contents": [
      { "x": 130, "y": 220 },
      { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
    ]
  }
}
