{
  "name": "coding-quota-bar-mac",
  "version": "1.0.0",
  "description": "Coding Plan usage monitor for macOS - system menu bar resident display",
  "main": "./out/main/index.js",
  "author": "coding-quota-bar-team",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "package:dir": "npm run build && electron-builder --dir",
    "package:mac": "npm run build && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.6"
  },
  "build": {
    "appId": "top.hyizhou.codingquotabar",
    "productName": "Coding Quota Bar",
    "copyright": "Copyright © 2026 coding-quota-bar-team",
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "electron-updater": "^6.8.3",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.3.0"
  }
}
